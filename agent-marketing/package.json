{
  "name": "agent-marketing",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:worker": "tsc -p tsconfig.worker.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start:web": "node scripts/start-web.mjs",
    "worker:dev": "tsx watch src/worker/index.ts",
    "worker:start": "tsx src/worker/index.ts",
    "worker:start:prod": "node dist-worker/worker/index.js",
    "deploy:migrate": "npm run db:migrate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@modelcontextprotocol/client": "latest",
    "@sentry/node": "^10.51.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-start": "latest",
    "drizzle-orm": "^0.45.2",
    "openai": "latest",
    "pg-boss": "^12.18.2",
    "postgres": "^3.4.9",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "latest",
    "vitest": "latest"
  }
}
