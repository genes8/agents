# OpenAI-compatible provider config. Defaults target DeepSeek.
OPENAI_API_KEY=your_deepseek_api_key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_DEFAULT_MODEL=deepseek-v4-pro
# The JSON repair/schema-correction loop is fixed in code. There is no OPENAI_FALLBACK_MODEL env var.

# Postgres connection string.
DATABASE_URL=postgres://agent_marketing:change-me@localhost:5432/agent_marketing
TEST_DATABASE_URL=postgres://agent_marketing:change-me@localhost:5432/postgres

# Optional generation tuning.
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# Optional MCP stdio servers as JSON. Leave empty to run without MCP tools.
# Example:
# MCP_STDIO_SERVERS=[{"name":"filesystem","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/Users/enes/Desktop/Dev/agent-marketing"]}]
MCP_STDIO_SERVERS=[]
